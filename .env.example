# Server Configuration
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info
DEBUG=false
RELOAD=false

# Security
SECRET_KEY=your-secret-key-here
ACCESS_TOKEN_EXPIRE_MINUTES=30
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]

# OpenAI (Required for Reporter Agent)
OPENAI_API_KEY=sk-placeholder

# Google Cloud Firestore (Required for Persistence)
# Leave empty to use in-memory mock repository (if implemented)
GOOGLE_APPLICATION_CREDENTIALS=service-account-key.json
FIRESTORE_PROJECT_ID=your-project-id

# Agent Configuration
WATCHER_AGENT_ID=watcher_01
ANALYST_AGENT_ID=analyst_01
REPORTER_AGENT_ID=reporter_01

# Crawler Config
CRAWLER_TIMEOUT=30000
CRAWLER_USE_PLAYWRIGHT=true
CRAWLER_WAIT_FOR=networkidle

# Scheduler
SCHEDULER_ENABLED=false
DEFAULT_USER_ID=demo_user
SCHEDULER_TIMEZONE=UTC
